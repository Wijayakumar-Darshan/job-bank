# ─────────────────────────────────────────────
#  SL Job Bank — Frontend Environment Variables
# ─────────────────────────────────────────────

# Backend API base URL
VITE_API_URL=http://localhost:8080/api

# Cloudinary (public key only — safe to expose)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=sljobbank_preset

# PayHere (sandbox)
VITE_PAYHERE_MERCHANT_ID=your_merchant_id
VITE_PAYHERE_ENV=sandbox
